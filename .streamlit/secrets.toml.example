# Streamlit secrets — copy this file to .streamlit/secrets.toml for local use
# On Streamlit Cloud, add these via the dashboard (Settings → Secrets)
# Never commit secrets.toml to git

OPENAI_API_KEY = "sk-your-openai-key-here"

ADMIN_EMAIL = "admin@example.com"
ADMIN_PASSWORD = "your-admin-password"

JUSTUS_EMAIL = "justus@example.com"
JUSTUS_PASSWORD = "your-justus-password"

GAST_EMAIL = "guest@example.com"
GAST_PASSWORD = "your-guest-password"

DB_PATH = "database/localization.db"
OPENAI_MODEL = "gpt-4o-mini"
TM_FUZZY_THRESHOLD = "0.75"
